<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:liftOnScroll="false">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/white"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIcon="@drawable/ic_pe_back"
            app:navigationIconTint="@android:color/black"
            app:title="Filter"
            app:titleTextAppearance="@style/TextAppearance.PE.Toolbar.Title"
            app:titleTextColor="@android:color/black">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_crop_page"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_pe_crop"
                    app:iconSize="24dp"
                    app:iconTint="@android:color/black" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_delete_page"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_pe_delete"
                    app:iconSize="24dp"
                    app:iconTint="@android:color/black" />

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Preview Container -->
    <LinearLayout
        android:id="@+id/preview_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <!-- ViewPager for pages (uses PerspectiveImageView for each page) -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_filter_apply_to_all"
            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|right"
            android:layout_marginEnd="16dp"
            android:text="@string/pe_apply_to_all"
            android:textColor="@android:color/black"
            android:visibility="gone"
            app:icon="@drawable/ic_pe_adjust"
            app:iconSize="20dp"
            app:iconTint="@android:color/black"
            app:strokeColor="@color/pe_accent" />

        <!-- Bottom controls overlay: indicator (center) + delete (end) -->
        <LinearLayout
            android:id="@+id/bottom_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:clipToPadding="false"
            android:gravity="center"
            android:paddingVertical="8dp">

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:id="@+id/page_indicator_container"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pe_page_indicator"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_prev_page"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@drawable/bg_pe_page_button"
                    android:contentDescription="@null"
                    android:padding="4dp"
                    android:src="@drawable/ic_pe_chevron_left"
                    app:tint="@android:color/white" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_page_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="10dp"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="1/2" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_next_page"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@drawable/bg_pe_page_button"
                    android:contentDescription="@null"
                    android:padding="4dp"
                    android:src="@drawable/ic_pe_chevron_right"
                    app:tint="@android:color/white" />

            </FrameLayout>

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/bottom_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="12dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_pe_filter" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@android:color/white"
                android:elevation="8dp"
                android:gravity="center"
                android:paddingHorizontal="16dp">

                <LinearLayout
                    android:id="@+id/btn_rotate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_pe_rotate"
                        app:tint="#424242" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/pe_rotate"
                        android:textColor="#424242"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_flip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_pe_flip"
                        app:tint="#424242" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/pe_flip"
                        android:textColor="#424242"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_adjust"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?selectableItemBackground"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_pe_adjust"
                        app:tint="#424242" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/pe_adjust"
                        android:textColor="#424242"
                        android:textSize="12sp" />

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnNext"
                    android:layout_width="80dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_btn_next1"
                    android:drawableStart="@drawable/ic_download_save"
                    android:elevation="0dp"
                    android:padding="8dp"
                    android:stateListAnimator="@null"
                    android:text="@string/pe_save"
                    android:textAllCaps="false"
                    android:textColor="#B3FF10"
                    android:textSize="14sp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/filter_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:color/white"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/btn_apply_to_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/pe_apply_to_all" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_adjust"
                    style="@style/Widget.PE.Slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="-12dp"
                    android:layout_marginEnd="48dp"
                    android:value="0"
                    android:valueFrom="-100"
                    android:valueTo="100" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_adjust_value"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                    tools:text="100" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_contrast"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/pe_color_adjust_background"
                    android:ellipsize="end"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="8dp"
                    android:text="@string/pe_contrast"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/pe_color_adjust_foreground"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_pe_contrast"
                    app:iconGravity="top"
                    app:iconSize="22dp"
                    app:iconTint="@color/pe_color_adjust_foreground" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_brightness"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/pe_color_adjust_background"
                    android:ellipsize="end"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="8dp"
                    android:text="@string/pe_brightness"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/pe_color_adjust_foreground"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_pe_brightness"
                    app:iconGravity="top"
                    app:iconSize="22dp"
                    app:iconTint="@color/pe_color_adjust_foreground" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_saturation"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/pe_color_adjust_background"
                    android:ellipsize="end"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="8dp"
                    android:text="@string/pe_saturation"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/pe_color_adjust_foreground"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_pe_saturation"
                    app:iconGravity="top"
                    app:iconSize="22dp"
                    app:iconTint="@color/pe_color_adjust_foreground" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_warmth"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/pe_color_adjust_background"
                    android:ellipsize="end"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:maxLines="1"
                    android:paddingHorizontal="8dp"
                    android:text="@string/pe_warmth"
                    android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                    android:textColor="@color/pe_color_adjust_foreground"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_pe_warmth"
                    app:iconGravity="top"
                    app:iconSize="22dp"
                    app:iconTint="@color/pe_color_adjust_foreground" />

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_cancel"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_pe_close"
                    app:tint="#000000" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/pe_adjust"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_submit"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="?selectableItemBackgroundBorderless"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_pe_check"
                    app:tint="@color/pe_accent" />

            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
