<?xml version="1.0" encoding="utf-8"?>
<!-- Nền dialog upsell: card tối gradient xanh + viền lime mờ (đồng bộ màn Premium) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#1C2B12"
        android:endColor="#0D1207"
        android:type="linear" />
    <corners android:radius="26dp" />
    <stroke
        android:width="1dp"
        android:color="#4DB3FF10" />
</shape>
