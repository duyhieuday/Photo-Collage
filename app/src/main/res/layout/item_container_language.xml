<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="18dp"
    android:paddingVertical="8dp">

    <RelativeLayout
        android:id="@+id/layoutItemLanguage"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_language"
        android:foreground="?android:selectableItemBackground"
        android:orientation="horizontal"
        android:weightSum="3"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="16dp"
            android:layout_centerVertical="true"
            >

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/circleFlagImage"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/english"
                android:visibility="visible"
                android:layout_centerVertical="true"
                />


            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/textItemLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="20dp"
                android:fontFamily="@font/inter_regular"
                android:text="English"
                android:textColor="#101828"
                android:textSize="14sp"
                android:layout_toEndOf="@id/circleFlagImage"
                android:layout_centerVertical="true"
                />

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iconItemCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_unselect"
                android:layout_centerVertical="true"
                />

        </RelativeLayout>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>