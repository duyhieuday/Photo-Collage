<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="@dimen/dimen_16dp"
    >

    <!--
        Thumbnail: tỉ lệ 9:16 (portrait) giống template thật
        Dùng wrap_content height + scaleType=centerCrop
    -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/imgThumb"
            android:layout_width="match_parent"
            android:layout_height="270dp"
            android:scaleType="centerCrop"
            app:riv_corner_radius="@dimen/dimen_8dp"
            />

        <!-- Badge premium (ẩn mặc định; adapter set runtime) -->
        <ImageView
            android:id="@+id/icTemplatePro"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:src="@drawable/ic_pro"
            android:visibility="gone"
            android:importantForAccessibility="no" />
    </FrameLayout>

</LinearLayout>
