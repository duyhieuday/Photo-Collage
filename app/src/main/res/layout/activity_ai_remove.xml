<?xml version="1.0" encoding="utf-8"?>
<layout>

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        tools:context=".AiRemoveActivity">

        <!-- Toolbar -->
        <RelativeLayout
            android:id="@+id/layoutBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/dimen_16dp"
            android:layout_marginTop="44dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:adjustViewBounds="true"
                android:padding="@dimen/dimen_8dp"
                android:src="@drawable/ic_back_new" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_btn_next1"
                android:elevation="0dp"
                android:fontFamily="@font/inter_medium"
                android:stateListAnimator="@null"
                android:text="@string/next"
                android:textAllCaps="false"
                android:textColor="#B3FF10"
                android:textSize="14sp" />

        </RelativeLayout>

        <!-- Image container -->
        <RelativeLayout
            android:id="@+id/rl_container"
            android:layout_width="match_parent"
            android:layout_height="410dp"
            android:layout_below="@+id/layoutBar"
            android:layout_marginHorizontal="@dimen/dimen_16dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="@dimen/dimen_16dp">

            <!-- Ảnh chính (gốc hoặc kết quả remove BG) -->
            <ImageView
                android:id="@+id/img_background"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_centerInParent="true"
                android:adjustViewBounds="true"
                android:scaleType="fitCenter"
                android:src="@drawable/img_remove_bg"
                />

            <!-- Lottie animation + text khi đang processing -->
            <LinearLayout
                android:id="@+id/ll_processing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottie_processing"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:lottie_speed="1"
                    app:lottie_autoPlay="true"
                    app:lottie_rawRes="@raw/loading_remove_bg"
                    app:lottie_loop="true"
                    />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/inter_medium"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="4"
                    android:text="AI is working on it ...0%"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Badge "Done!" khi xử lý xong -->
            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tv_done"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/img_background"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="-32dp"
                android:background="@drawable/bg_done_badge"
                android:fontFamily="@font/inter_medium"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="@string/done"
                android:textColor="#039855"
                android:textSize="14sp"
                android:visibility="gone" />

        </RelativeLayout>

        <!-- Ads -->
        <LinearLayout
            android:id="@+id/layoutAds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/ad_view_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#ffffff" />

            <include
                android:id="@+id/banner"
                layout="@layout/banner_ads"
                android:visibility="visible" />
        </LinearLayout>

    </RelativeLayout>
</layout>