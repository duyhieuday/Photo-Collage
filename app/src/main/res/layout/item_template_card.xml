<?xml version="1.0" encoding="utf-8"?>
<!-- Card thumbnail dọc (9:16) cho hàng cuộn ngang trong mỗi category -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="108dp"
    android:layout_height="192dp"
    android:layout_marginEnd="@dimen/dimen_8dp">

    <com.makeramen.roundedimageview.RoundedImageView
        android:id="@+id/imgThumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#EDEDED"
        app:riv_corner_radius="@dimen/dimen_8dp" />

    <!-- Badge premium (ẩn mặc định; adapter set runtime cho template premium + user free) -->
    <ImageView
        android:id="@+id/icTemplatePro"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_pro"
        android:visibility="gone"
        android:importantForAccessibility="no" />
</FrameLayout>
