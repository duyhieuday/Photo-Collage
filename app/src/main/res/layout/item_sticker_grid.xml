<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <FrameLayout
        android:id="@+id/stickerRoot"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_sticker_item">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/stickerImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="4dp"
            android:scaleType="fitCenter" />

        <!-- Badge premium (ẩn mặc định; adapter set runtime cho sticker premium + user free) -->
        <ImageView
            android:id="@+id/stickerPro"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="top|end"
            android:elevation="2dp"
            android:src="@drawable/ic_pro"
            android:visibility="gone"
            android:importantForAccessibility="no" />
    </FrameLayout>
</FrameLayout>
