<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:orientation="vertical">



        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">



                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        app:layout_constraintTop_toTopOf="parent"
                        android:src="@drawable/banner"
                        app:layout_constraintDimensionRatio="1024:500"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"/>


                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="30dp"/>

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        app:layout_constraintTop_toTopOf="parent"
                        android:src="@drawable/ipaaaaa"
                        app:layout_constraintDimensionRatio="1080:1121"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"/>


                </androidx.constraintlayout.widget.ConstraintLayout>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- YEARLY -->
                    <LinearLayout
                        android:id="@+id/layoutYearly"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_option_selected"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/icYearly"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_radio_selected"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="12dp">

                            <TextView
                                android:id="@+id/tvYearly"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="Yearly"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@android:color/white"/>

                            <TextView
                                android:visibility="gone"
                                android:layout_height="wrap_content"
                                android:layout_width="wrap_content"
                                android:text="3 day free trial"
                                android:textSize="13sp"
                                android:textColor="@android:color/white"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvYearlyPrice"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="_"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@android:color/white"/>
                    </LinearLayout>

                    <!-- WEEKLY -->
                    <LinearLayout
                        android:id="@+id/layoutWeekly"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_option_unselected"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/icWeekly"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_radio_unselected"/>

                        <TextView
                            android:id="@+id/tvWeekly"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="12dp"
                            android:text="Weekly"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"/>

                        <TextView
                            android:id="@+id/tvWeeklyPrice"
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="_"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textColor="@android:color/black"/>
                    </LinearLayout>

                </LinearLayout>


                <LinearLayout
                    android:alpha="0"
                    android:layout_marginBottom="20dp"
                    android:background="@color/white"
                    android:paddingVertical="20dp"
                    android:layout_alignParentBottom="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">




                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnGo"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="#3D73BA"
                        android:layout_marginHorizontal="20dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">


                        <TextView
                            android:fontFamily="@font/inter_bold"
                            android:textSize="20dp"
                            android:gravity="center"
                            android:layout_marginVertical="18dp"
                            android:textColor="@color/white"
                            android:text="Continue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>


                    </androidx.cardview.widget.CardView>


                </LinearLayout>





                <LinearLayout
                    android:visibility="gone"
                    android:background="@color/black"
                    android:layout_marginBottom="50dp"
                    android:layout_alignParentBottom="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="15dp">


                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <LinearLayout
                                android:id="@+id/viewBuy1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingVertical="10dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />

                                <TextView
                                    android:textColor="@color/white"
                                    android:id="@+id/tvPrice1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="_"
                                    android:textSize="25dp" />


                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Per Month"
                                    android:textAllCaps="true"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />


                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/viewBorder1"
                                android:orientation="horizontal"
                                android:visibility="gone"
                                android:layout_alignParentTop="true"
                                android:layout_alignBottom="@+id/viewBuy1"
                                android:layout_width="match_parent"
                                android:layout_height="0dp" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1">

                            <LinearLayout
                                android:id="@+id/viewBuy2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingVertical="10dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Save 80%"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />

                                <TextView
                                    android:id="@+id/tvPrice2"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="_"
                                    android:textSize="25dp" />


                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Per 6 Months"
                                    android:textAllCaps="true"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />


                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/viewBorder2"
                                android:orientation="horizontal"
                                android:visibility="gone"
                                android:layout_alignParentTop="true"
                                android:layout_alignBottom="@+id/viewBuy2"
                                android:layout_width="match_parent"
                                android:layout_height="0dp" />

                        </RelativeLayout>


                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:paddingHorizontal="15dp">


                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <LinearLayout
                                android:id="@+id/viewBuy3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingVertical="10dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Save 90%"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />

                                <TextView
                                    android:id="@+id/tvPrice3"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="_"
                                    android:textSize="25dp" />


                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="Per year"
                                    android:textAllCaps="true"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />


                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/viewBorder3"
                                android:visibility="gone"
                                android:layout_alignParentTop="true"
                                android:layout_alignBottom="@+id/viewBuy3"
                                android:layout_width="match_parent"
                                android:layout_height="0dp" />

                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_weight="1">

                            <LinearLayout
                                android:id="@+id/viewBuy4"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingVertical="10dp">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="One time payment"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />

                                <TextView
                                    android:id="@+id/tvPrice4"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="_"
                                    android:textSize="25dp" />


                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:text="lifetime"
                                    android:textAllCaps="true"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />


                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/viewBorder4"
                                android:visibility="gone"
                                android:layout_alignParentTop="true"
                                android:layout_alignBottom="@+id/viewBuy4"
                                android:layout_width="match_parent"
                                android:layout_height="0dp" />

                        </RelativeLayout>


                    </LinearLayout>

                    <TextView
                        android:layout_marginTop="20dp"
                        android:layout_marginHorizontal="15dp"
                        android:textColor="@color/white"
                        android:gravity="start"
                        android:text="One-month, six-month and one-year subscriptions will auto-renew. You can cancel anytime."
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>


        </androidx.core.widget.NestedScrollView>



        <ImageView
            android:src="@drawable/ic_close_ab"
            android:id="@+id/img_back"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginTop="5dp"
            android:padding="14dp"
            android:tint="#D9B1BD"
            tools:ignore="UseAppTint" />



        <LinearLayout
            android:background="@color/white"
            android:paddingVertical="20dp"
            android:layout_alignParentBottom="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">




            <androidx.cardview.widget.CardView
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#3D73BA"
                android:layout_marginHorizontal="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <TextView
                    android:fontFamily="@font/inter_bold"
                    android:textSize="20dp"
                    android:gravity="center"
                    android:layout_marginVertical="18dp"
                    android:textColor="@color/white"
                    android:text="Continue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>


            </androidx.cardview.widget.CardView>


        </LinearLayout>




    </RelativeLayout>
</layout>