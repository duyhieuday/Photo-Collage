<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical">

    <!-- Contrast -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="@string/pe_contrast"
            android:textColor="@android:color/black"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_contrast"
            style="@style/Widget.PE.Slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:value="0"
            android:valueFrom="-50"
            android:valueTo="50" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_contrast_value"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="#757575"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Brightness -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="@string/pe_brightness"
            android:textColor="@android:color/black"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_brightness"
            style="@style/Widget.PE.Slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:value="0"
            android:valueFrom="-50"
            android:valueTo="50" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_brightness_value"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="#757575"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Sharpen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="@string/pe_sharpen"
            android:textColor="@android:color/black"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_sharpen"
            style="@style/Widget.PE.Slider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:value="0"
            android:valueFrom="-50"
            android:valueTo="50" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tv_sharpen_value"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="#757575"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Reset button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_reset"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/pe_reset"
        android:textAllCaps="false"
        android:textColor="@color/pe_accent"
        android:textSize="14sp"
        app:icon="@drawable/ic_pe_reset"
        app:iconGravity="textStart"
        app:iconSize="18dp"
        app:iconTint="@color/pe_accent" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#E0E0E0" />

    <!-- Bottom actions -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="64dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btn_adjust_cancel"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:src="@drawable/ic_pe_close"
            app:tint="#000000" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/pe_adjust"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btn_adjust_submit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="@null"
            android:src="@drawable/ic_pe_check"
            app:tint="@color/pe_accent" />

    </FrameLayout>

</LinearLayout>
