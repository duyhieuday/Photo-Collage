<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Preview Container -->
    <FrameLayout
        android:id="@+id/preview_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- ViewPager for pages (uses PerspectiveImageView for each page) -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Bottom controls overlay: indicator (center) + delete (end) -->
        <LinearLayout
            android:id="@+id/bottom_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:clipToPadding="false"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="12dp">

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:id="@+id/page_indicator_container"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="@drawable/bg_pe_page_indicator"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_prev_page"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="start|center_vertical"
                    android:background="@drawable/bg_pe_page_button"
                    android:contentDescription="@null"
                    android:padding="4dp"
                    android:src="@drawable/ic_pe_chevron_left"
                    app:tint="@android:color/white" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tv_page_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="10dp"
                    android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    tools:text="1/2" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_next_page"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@drawable/bg_pe_page_button"
                    android:contentDescription="@null"
                    android:padding="4dp"
                    android:src="@drawable/ic_pe_chevron_right"
                    app:tint="@android:color/white" />


            </FrameLayout>

            <!-- Delete button (end) -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btn_delete_page"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_pe_page_indicator"
                    android:contentDescription="@null"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_pe_delete"
                    app:tint="@android:color/white" />

            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Bottom Bar Container -->
    <FrameLayout
        android:id="@+id/bottom_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Main Toolbar (Filter | Crop | Adjust) -->
        <include
            android:id="@+id/bottom_toolbar"
            layout="@layout/layout_pe_main_toolbar" />

        <!-- Filter Panel -->
        <include
            android:id="@+id/filter_panel"
            layout="@layout/layout_pe_filter_panel"
            android:visibility="gone" />

        <!-- Crop Panel -->
        <include
            android:id="@+id/crop_panel"
            layout="@layout/layout_pe_crop_panel"
            android:visibility="gone" />

        <!-- Adjust Panel -->
        <include
            android:id="@+id/adjust_panel"
            layout="@layout/layout_pe_adjust_panel"
            android:visibility="gone" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
